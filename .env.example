DATABASE_URL="postgresql://user:password@localhost:5432/club_nexus"

NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ── OAuth providers (optional, add if you want social login) ─────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ── Email (optional, set provider to "resend" in production) ─────────────────
EMAIL_PROVIDER="console"   # "console" | "resend"
EMAIL_FROM="noreply@clubnexus.app"
RESEND_API_KEY=""

# ── File uploads (optional, for product images and shared files) ─────────────
# Recommended: use Cloudinary or S3 + pre-signed URLs
# Upload directly from client to CDN; store URL in DB.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Push notifications — Firebase Admin SDK ───────────────────────────────────
# Create a service account in Firebase Console → Project Settings → Service accounts
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""   # paste full key including \n newlines

# ── Cron job security ─────────────────────────────────────────────────────────
# Must match the Authorization: Bearer <token> header sent by Vercel Cron
CRON_SECRET="generate-a-random-secret-min-32-chars"
