// Club Nexus - Multi-tenant SaaS for sports clubs
// Multi-tenancy strategy: Row-level isolation
// Every club-scoped table carries clubId + indexed for performant queries at 100+ clubs

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Enable connection pooling via DATABASE_URL pointing to PgBouncer/Prisma Accelerate in production
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  CLUB_ADMIN
  SOCIO
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
  BANNED       // expelled with permanent block — can only be lifted by admin
  LEFT         // voluntary departure — may rejoin if club policy allows
}

enum ClubVisibility {
  PUBLIC       // appears in directory, anyone can request
  PRIVATE      // appears in directory, requires invitation or approved request
  HIDDEN       // not in directory, only accessible via direct link/code
}

enum JoinPolicy {
  OPEN         // auto-approved on request
  REQUEST      // request + manual admin approval
  INVITE_ONLY  // only users with a valid invitation can join
}

enum InvitationStatus {
  PENDING      // sent, not yet used
  ACCEPTED     // used, membership created
  EXPIRED      // expiresAt passed without use
  REVOKED      // manually cancelled by admin
  REJECTED     // explicitly declined by the recipient
}

enum InvitationChannel {
  EMAIL        // direct invitation to a specific email
  LINK         // shareable public link
  CODE         // short alphanumeric access code
}

enum TransactionType {
  INCOME
  EXPENSE
}

// Source of a bank movement — enforces idempotency and traceability
enum MovementSource {
  FEE        // MemberQuota payment
  EVENT      // EventPayment (paid event registration)
  ORDER      // OrderPayment (purchase order)
  INVOICE    // Invoice approval (expense)
  MANUAL     // manually entered by admin
  ADJUSTMENT // corrective entry (reversal / amendment)
}

// Generic payment status for EventPayment and OrderPayment
enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
}

enum QuotaStatus {
  PENDING
  PAID
  OVERDUE
}

enum PurchaseWindowStatus {
  DRAFT
  OPEN
  CLOSED
  SCHEDULED   // window that opens automatically at a scheduled time
}

enum OrderStatus {
  PENDING       // placed, awaiting payment
  PAID          // payment received — triggers BankMovement
  CONFIRMED     // admin confirmed/preparing
  DELIVERED     // physically delivered to member
  CANCELLED
}

enum ProductCategory {
  CLOTHING
  FOOTWEAR
  ACCESSORIES
  EQUIPMENT
  OTHER
}

enum MessageStatus {
  DRAFT
  SENT
}

enum AnnouncementTarget {
  ALL          // all users of the platform (SuperAdmin only)
  CLUB         // all members of one club
  SPORT        // all clubs of a given sport
  PROVINCE     // clubs in a province
  LOCALITY     // clubs in a locality
}

enum SubscriptionPlan {
  FREE        // up to 30 members, basic modules
  PRO         // up to 150 members
  PREMIUM     // up to 500 members
  ENTERPRISE  // unlimited
}

enum EventType {
  TRAINING
  RACE
  SOCIAL
  MEETING
  TRIP
  OTHER
}

enum AttendeeStatus {
  GOING
  NOT_GOING
  MAYBE
}

enum MemberProfileStatus {
  UNREGISTERED  // pre-created by admin, no user account yet
  LINKED        // linked to a real User account
}

enum NotificationType {
  EVENT_REMINDER    // upcoming event (24h / 2h before)
  PAYMENT_DUE       // quota or order overdue
  PAYMENT_RECEIVED  // payment confirmed
  NEW_MEMBER        // new member joined club
  TICKET_REPLY      // support ticket reply
  SYSTEM            // generic platform announcement
  PURCHASE_UPDATE   // order status changed
}

enum NotificationJobStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum TicketStatus {
  OPEN          // newly created, awaiting first response
  IN_PROGRESS   // being handled
  WAITING       // waiting for user / club reply
  RESOLVED      // marked solved, pending confirmation
  CLOSED        // permanently closed
}

enum TicketPriority {
  LOW           // FREE plan clubs or general inquiries
  MEDIUM        // PRO plan clubs
  HIGH          // PREMIUM plan clubs
  URGENT        // ENTERPRISE plan clubs or critical issues
}

enum TicketCategory {
  BILLING       // Stripe, cuotas, cobros duplicados
  TECHNICAL     // App no carga, inscripciones fallidas
  REPORT        // Denuncia de comportamiento
  INQUIRY       // Consulta general
}

// ─── Core: Users & Auth ───────────────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String?  // nullable to support OAuth-only accounts
  role          UserRole @default(SOCIO)
  avatarUrl     String?
  // Location for segmented announcements
  province      String?
  locality      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // OAuth accounts (Google, GitHub, etc.)
  accounts      OAuthAccount[]

  memberships         ClubMembership[]
  voteResponses       VoteResponse[]
  orders              Order[]
  auditLogs           AuditLog[]
  notifications       Notification[]
  sentMessages        ClubMessage[]         @relation("MessageSender")
  receivedMessages    ClubMessageRecipient[]
  passwordResets      PasswordReset[]
  eventAttendances    EventAttendee[]
  eventPayments       EventPayment[]
  createdInvitations  ClubInvitation[]      @relation("InvitationCreator")
  targetedInvitations ClubInvitation[]      @relation("InvitationTarget")
  acceptedInvitations ClubInvitation[]      @relation("InvitationAcceptor")
  memberProfiles      ClubMemberProfile[]
  createdTickets         Ticket[]                  @relation("TicketCreator")
  assignedTickets        Ticket[]                  @relation("TicketAssignee")
  escalatedTickets       Ticket[]                  @relation("TicketEscalator")
  ticketMessages         TicketMessage[]
  notificationPrefs      NotificationPreference[]
  devices                UserDevice[]

  @@index([email])
  @@index([role])
  @@index([province])
  @@index([locality])
}

// OAuth accounts linked to a User (NextAuth Adapter pattern, manual implementation)
model OAuthAccount {
  id                String  @id @default(cuid())
  userId            String
  provider          String  // "google" | "github" | "facebook"
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
}

// ─── Club (Tenant) ─────────────────────────────────────────────────────────

model Club {
  id          String   @id @default(cuid())
  name        String
  slogan      String?
  sport       String   // from Sports master table
  colorTheme  String   @default("blue")
  logoUrl     String?
  active      Boolean  @default(true)
  // Location metadata (for announcement segmentation)
  province    String?
  locality    String?
  country     String?  @default("España")
  // Contact
  contactEmail String?
  contactPhone String?
  website      String?
  // Description shown on public club page
  description  String?
  foundedYear  Int?
  // Access control
  visibility              ClubVisibility @default(PUBLIC)
  joinPolicy              JoinPolicy     @default(REQUEST)
  autoApprove             Boolean        @default(false)
  inviteLinksEnabled      Boolean        @default(true)
  defaultInviteExpiryDays Int?           @default(7)
  defaultInviteMaxUses    Int?           @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  memberships       ClubMembership[]
  bankAccount       BankAccount?
  ledgerCategories  LedgerCategory[]
  bankMovements     BankMovement[]
  sizeGroups        SizeGroup[]
  productCategories ClubProductCategory[]
  products          Product[]
  purchaseWindows   PurchaseWindow[]
  votes             Vote[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  invoices          Invoice[]
  messages          ClubMessage[]
  clubAnnouncements ClubAnnouncement[]
  sharedFiles       SharedFile[]
  subscription      ClubSubscription?
  moduleAccess      ClubModuleAccess[]
  events            ClubEvent[]
  customRoles       ClubCustomRole[]
  invitations       ClubInvitation[]
  memberProfiles    ClubMemberProfile[]
  tickets           Ticket[]

  @@index([active])
  @@index([sport])
  @@index([province])
  @@index([locality])
}

// ─── Membership (User ↔ Club) — one user can belong to MANY clubs ─────────

model ClubMembership {
  id        String           @id @default(cuid())
  userId    String
  clubId    String
  status    MembershipStatus @default(PENDING)
  role      UserRole         @default(SOCIO)
  joinedAt  DateTime?
  // Ban tracking
  bannedAt      DateTime?
  bannedById    String?
  bannedReason  String?
  // Voluntary departure
  leftAt        DateTime?
  // Invitation that originated this membership (null = direct request)
  invitationId  String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user        User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  club        Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  quotas      MemberQuota[]
  customRoles ClubMemberCustomRole[]
  invitation  ClubInvitation?        @relation(fields: [invitationId], references: [id])
  memberProfile ClubMemberProfile?

  @@unique([userId, clubId])
  @@index([clubId, status])          // most common query: list members of club by status
  @@index([userId])                  // all clubs a user belongs to
  @@index([clubId, role])
  @@index([invitationId])
}

// ─── Club Invitations ─────────────────────────────────────────────────────

model ClubInvitation {
  id              String            @id @default(cuid())
  clubId          String

  invitedById     String            // userId of the admin who created the invitation

  // Target (null = generic link/code)
  invitedEmail    String?           // for direct email invitations
  invitedUserId   String?           // if the target user already exists in the platform

  // Token — always present regardless of channel
  token           String            @unique  // crypto.randomBytes(32).toString('hex')

  channel         InvitationChannel @default(EMAIL)
  status          InvitationStatus  @default(PENDING)

  // Role assigned upon joining
  assignedRole    UserRole          @default(SOCIO)

  // Usage control
  maxUses         Int?              // null = single use (email default); >1 for links
  usesCount       Int               @default(0)

  // Expiry
  expiresAt       DateTime?

  // Traceability
  acceptedAt        DateTime?
  acceptedByUserId  String?
  revokedAt         DateTime?
  revokedById       String?
  note              String?         // internal admin note, not shown to recipient

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  club            Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  invitedBy       User              @relation("InvitationCreator", fields: [invitedById], references: [id])
  invitedUser     User?             @relation("InvitationTarget", fields: [invitedUserId], references: [id])
  acceptedBy      User?             @relation("InvitationAcceptor", fields: [acceptedByUserId], references: [id])
  memberships     ClubMembership[]

  @@index([clubId, status])
  @@index([token])
  @@index([invitedEmail])
  @@index([clubId, channel, status])
  @@index([expiresAt])
}

// ─── Accounting / Banking ─────────────────────────────────────────────────

// BankAccount — 1:1 with Club. Acts as "accounting enabled" flag + optional metadata.
// Balance is never stored here; it is always computed as SUM(INCOME) - SUM(EXPENSE) from BankMovement.
model BankAccount {
  id        String   @id @default(cuid())
  clubId    String   @unique
  // Optional metadata (informational only)
  bankName  String?
  iban      String?
  holder    String?
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

// Unified category for both income and expense movements
model LedgerCategory {
  id        String          @id @default(cuid())
  clubId    String
  name      String
  type      TransactionType // INCOME | EXPENSE
  color     String?         // hex color for chart display, e.g. "#10b981"
  createdAt DateTime        @default(now())

  club      Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  movements BankMovement[]

  @@unique([clubId, name, type])
  @@index([clubId, type])
}

// Append-only ledger — entries are NEVER modified after creation.
// For corrections, create a new ADJUSTMENT entry.
// Idempotency: @@unique([source, sourceId]) prevents double-recording the same payment.
model BankMovement {
  id          String          @id @default(cuid())
  clubId      String
  type        TransactionType // INCOME | EXPENSE
  amount      Decimal         @db.Decimal(14, 2)
  description String
  categoryId  String?
  source      MovementSource  @default(MANUAL)
  sourceId    String?         // ID of the originating record (quotaId, orderId, invoiceId, eventPaymentId)
  date        DateTime        @default(now())
  createdAt   DateTime        @default(now())

  club     Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  category LedgerCategory? @relation(fields: [categoryId], references: [id])

  // Idempotency guard: one movement per source entity
  @@unique([source, sourceId])
  @@index([clubId, date(sort: Desc)])
  @@index([clubId, type])
  @@index([clubId, source])
  @@index([clubId, createdAt(sort: Desc)])
}

model Invoice {
  id          String   @id @default(cuid())
  clubId      String
  amount      Decimal  @db.Decimal(14, 2)
  description String
  supplier    String
  fileUrl     String?
  approved    Boolean  @default(false)
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  // BankMovement is linked via source='INVOICE', sourceId=invoice.id — no direct relation needed
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, approved])
  @@index([clubId, date(sort: Desc)])
}

model MemberQuota {
  id           String      @id @default(cuid())
  membershipId String
  clubId       String      // denormalized for direct club queries
  year         Int
  amount       Decimal     @db.Decimal(14, 2)
  status       QuotaStatus @default(PENDING)
  dueDate      DateTime?   // specific payment deadline (null = open-ended)
  paidAt       DateTime?
  createdAt    DateTime    @default(now())

  // BankMovement is linked via source='FEE', sourceId=quota.id — no direct relation needed
  membership ClubMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)

  @@unique([membershipId, year])
  @@index([clubId, status])        // view all pending quotas in a club
  @@index([clubId, year])
  @@index([clubId, dueDate])
}

// ─── Maestros ─────────────────────────────────────────────────────────────

model SizeGroup {
  id        String   @id @default(cuid())
  clubId    String
  name      String   // e.g. "Ropa adulto", "Calzado", "Unitalla"
  // Ordered list of sizes — from XXS to XXXL for clothing, numeric for shoes, etc.
  sizes     String[] // ["XXS","XS","S","M","L","XL","XXL","XXXL"] or ["35","36",...,"48"]
  createdAt DateTime @default(now())

  club     Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([clubId])
}

// Club-level product categories (e.g. "Maillots", "Cascos", "Bidones")
model ClubProductCategory {
  id        String   @id @default(cuid())
  clubId    String
  name      String
  order     Int      @default(0)
  createdAt DateTime @default(now())

  club     Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  products Product[]

  @@index([clubId])
}

// ─── Compras Conjuntas ────────────────────────────────────────────────────

model Product {
  id                  String          @id @default(cuid())
  clubId              String
  categoryId          String?         // ClubProductCategory
  sizeGroupId         String?         // SizeGroup for this product
  name                String
  description         String?
  price               Decimal         @db.Decimal(14, 2)
  images              String[]        // multiple image URLs
  availableSizes      String[]        // subset of the SizeGroup sizes actually available
  totalStock          Int?
  category            ProductCategory @default(CLOTHING)
  active              Boolean         @default(true)
  // Scheduled activation window
  activeFrom          DateTime?
  activeTo            DateTime?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  club            Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  productCategory ClubProductCategory?    @relation(fields: [categoryId], references: [id])
  sizeGroup       SizeGroup?              @relation(fields: [sizeGroupId], references: [id])
  orderItems      OrderItem[]
  purchaseWindows PurchaseWindowProduct[]

  @@index([clubId, active])
  @@index([clubId, categoryId])
  @@index([clubId, activeFrom, activeTo])
}

model PurchaseWindow {
  id          String               @id @default(cuid())
  clubId      String
  name        String
  description String?
  status      PurchaseWindowStatus @default(DRAFT)
  openedAt    DateTime?
  closedAt    DateTime?
  // Scheduled auto-open/close
  scheduledOpenAt  DateTime?
  scheduledCloseAt DateTime?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  club     Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  products PurchaseWindowProduct[]
  orders   Order[]

  @@index([clubId, status])
  @@index([clubId, scheduledOpenAt])
}

model PurchaseWindowProduct {
  id               String @id @default(cuid())
  purchaseWindowId String
  productId        String

  purchaseWindow PurchaseWindow @relation(fields: [purchaseWindowId], references: [id], onDelete: Cascade)
  product        Product        @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([purchaseWindowId, productId])
  @@index([purchaseWindowId])
}

model Order {
  id               String      @id @default(cuid())
  userId           String
  clubId           String      // denormalized
  purchaseWindowId String
  status           OrderStatus @default(PENDING)
  totalAmount      Decimal     @db.Decimal(14, 2)
  notes            String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseWindow PurchaseWindow @relation(fields: [purchaseWindowId], references: [id], onDelete: Cascade)
  items          OrderItem[]
  payment        OrderPayment?

  @@index([clubId, purchaseWindowId])     // export by campaign
  @@index([clubId, status])
  @@index([userId, clubId])               // member's orders
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  clubId    String  // denormalized for report queries
  size      String
  quantity  Int
  price     Decimal @db.Decimal(14, 2)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([clubId, productId, size])       // aggregate report: qty by product+size
}

// ─── Votaciones ───────────────────────────────────────────────────────────

model Vote {
  id          String    @id @default(cuid())
  clubId      String
  title       String
  description String?
  active      Boolean   @default(true)
  closedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  club      Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  options   VoteOption[]
  responses VoteResponse[]

  @@index([clubId, active])
}

model VoteOption {
  id     String @id @default(cuid())
  voteId String
  text   String
  order  Int    @default(0)

  vote      Vote           @relation(fields: [voteId], references: [id], onDelete: Cascade)
  responses VoteResponse[]

  @@index([voteId])
}

model VoteResponse {
  id          String   @id @default(cuid())
  voteId      String
  userId      String
  optionId    String
  clubId      String   // denormalized
  respondedAt DateTime @default(now())

  vote   Vote       @relation(fields: [voteId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  option VoteOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([voteId, userId])             // 1 voto por socio
  @@index([clubId, voteId])
}

// ─── Mensajería interna del club ──────────────────────────────────────────

model ClubMessage {
  id         String        @id @default(cuid())
  clubId     String
  senderId   String
  subject    String
  body       String        @db.Text
  status     MessageStatus @default(DRAFT)
  // Who receives: ALL members, specific roles, or specific users
  targetRole UserRole?     // null = specific recipients; set = broadcast to role
  sentAt     DateTime?
  createdAt  DateTime      @default(now())

  club       Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sender     User                   @relation("MessageSender", fields: [senderId], references: [id])
  recipients ClubMessageRecipient[]
  emailLogs  MessageEmailLog[]

  @@index([clubId, status])
  @@index([clubId, sentAt(sort: Desc)])
}

model ClubMessageRecipient {
  id        String    @id @default(cuid())
  messageId String
  userId    String
  read      Boolean   @default(false)
  readAt    DateTime?

  message ClubMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, read])
}

model MessageEmailLog {
  id        String   @id @default(cuid())
  messageId String
  email     String
  status    String   // "sent" | "failed" | "bounced"
  sentAt    DateTime @default(now())

  message ClubMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

// ─── Anuncios del Club (Admin → Socios) ──────────────────────────────────

model ClubAnnouncement {
  id         String    @id @default(cuid())
  clubId     String
  authorId   String    // ClubAdmin who created it
  title      String
  body       String    @db.Text
  imageUrl   String?
  pinned     Boolean   @default(false)
  publishAt  DateTime  @default(now())
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  club        Club         @relation(fields: [clubId], references: [id], onDelete: Cascade)
  sharedFiles SharedFile[]

  @@index([clubId, publishAt(sort: Desc)])
  @@index([clubId, pinned])
  @@index([clubId, expiresAt])
}

model SharedFile {
  id             String    @id @default(cuid())
  clubId         String
  announcementId String?
  uploadedBy     String
  name           String
  url            String
  size           Int?      // bytes
  mimeType       String?
  createdAt      DateTime  @default(now())

  club         Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  announcement ClubAnnouncement? @relation(fields: [announcementId], references: [id])

  @@index([clubId, createdAt(sort: Desc)])
}

// ─── Anuncios del SuperAdmin (Plataforma global) ──────────────────────────

model PlatformBanner {
  id             String             @id @default(cuid())
  title          String
  body           String
  imageUrl       String?
  linkUrl        String?
  linkLabel      String?
  // Targeting
  targetType     AnnouncementTarget @default(ALL)
  targetSport    String?    // filter by sport
  targetProvince String?    // filter by province
  targetLocality String?    // filter by locality
  targetClubIds  String[]   // specific clubs (overrides other filters)
  targetRoles    UserRole[] // CLUB_ADMIN | SOCIO | both
  // Scheduling
  active         Boolean  @default(true)
  publishAt      DateTime @default(now())
  expiresAt      DateTime?
  // Metrics
  viewCount      Int      @default(0)
  clickCount     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([active, publishAt])
  @@index([targetType])
  @@index([targetSport])
  @@index([targetProvince])
}

// ─── Auditoría ─────────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  clubId    String
  userId    String
  action    String   // CREATE | UPDATE | DELETE | APPROVE | PAY | ...
  entity    String   // Invoice | Quota | Member | Order | Vote | BankAccount
  entityId  String?
  details   Json?    // snapshot of relevant data
  ip        String?
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([clubId, createdAt(sort: Desc)])   // main audit log view
  @@index([clubId, entity])
  @@index([clubId, userId])
}

// ─── Notificaciones ────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  clubId    String?          // null for platform-wide notifications
  type      NotificationType @default(SYSTEM)
  title     String
  message   String
  link      String?          // optional deep-link
  read      Boolean          @default(false)
  metadata  Json?            // extra data for rich rendering (eventId, amount, etc.)
  createdAt DateTime         @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club? @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, type])
}

// User preferences per notification type and channel
model NotificationPreference {
  id     String           @id @default(cuid())
  userId String
  type   NotificationType
  inApp  Boolean          @default(true)
  push   Boolean          @default(true)
  email  Boolean          @default(false) // opt-in: weekly digest only

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@index([userId])
}

// FCM device tokens for push notifications
model UserDevice {
  id        String   @id @default(cuid())
  userId    String
  fcmToken  String   @unique
  platform  String   // "web" | "android" | "ios"
  userAgent String?
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Background job queue — processed by /api/cron/process-queue (Vercel Cron)
model NotificationJob {
  id          String                @id @default(cuid())
  jobType     String                // "event_reminder_24h" | "event_reminder_2h" | "payment_reminder" | "weekly_digest"
  payload     Json
  status      NotificationJobStatus @default(PENDING)
  scheduledAt DateTime              // when the job should run (not before)
  processedAt DateTime?
  error       String?
  createdAt   DateTime              @default(now())

  @@index([status, scheduledAt])
  @@index([jobType, status])
}

// ─── Catálogo global (maestros del sistema) ───────────────────────────────

model Sport {
  id    String @id @default(cuid())
  name  String @unique
  icon  String // lucide icon name
  order Int    @default(0)
}

// ─── Sistema de Módulos y Planes ─────────────────────────────────────────────

model PlatformModule {
  id              String             @id @default(cuid())
  key             String             @unique  // e.g. "accounting", "purchases", "votes", "messaging", "events"
  name            String
  description     String?
  icon            String?            // lucide icon name
  stable          Boolean            @default(true)
  version         String             @default("1.0")
  // Which plans include this module by default
  includedInPlans SubscriptionPlan[]
  createdAt       DateTime           @default(now())

  clubAccess ClubModuleAccess[]
}

model ClubModuleAccess {
  id             String    @id @default(cuid())
  clubId         String
  moduleId       String
  enabled        Boolean   @default(true)
  // Override: SuperAdmin can grant access regardless of plan
  grantedByAdmin Boolean   @default(false)
  trialEndsAt    DateTime?
  enabledAt      DateTime  @default(now())

  club   Club           @relation(fields: [clubId], references: [id], onDelete: Cascade)
  module PlatformModule @relation(fields: [moduleId], references: [id])

  @@unique([clubId, moduleId])
  @@index([clubId, enabled])
}

// ─── Suscripción del Club ──────────────────────────────────────────────────

model ClubSubscription {
  id          String           @id @default(cuid())
  clubId      String           @unique
  plan        SubscriptionPlan @default(FREE)
  memberLimit Int?             // null = unlimited (ENTERPRISE)
  validFrom   DateTime         @default(now())
  validTo     DateTime?        // null = perpetual
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
}

// ─── Calendario de Eventos ────────────────────────────────────────────────

model ClubEvent {
  id           String    @id @default(cuid())
  clubId       String
  authorId     String
  type         EventType @default(OTHER)
  title        String
  description  String?
  location     String?
  startAt      DateTime
  endAt        DateTime?
  allDay       Boolean   @default(false)
  maxAttendees Int?
  price        Decimal?  @db.Decimal(14, 2)  // null = free; set = requires EventPayment
  imageUrl     String?
  published    Boolean   @default(true)
  shareToken   String?   @unique  // for public share links
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  club        Club                @relation(fields: [clubId], references: [id], onDelete: Cascade)
  attendees   EventAttendee[]
  attachments EventAttachment[]
  payments    EventPayment[]

  @@index([clubId, startAt])
  @@index([clubId, published])
  @@index([shareToken])
}

// ─── Adjuntos de eventos ──────────────────────────────────────────────────

model EventAttachment {
  id           String   @id @default(cuid())
  eventId      String
  clubId       String   // denormalized for isolation
  name         String
  url          String
  size         Int?     // bytes
  mimeType     String?
  uploadedById String
  createdAt    DateTime @default(now())

  event ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([clubId])
}

model EventAttendee {
  id          String         @id @default(cuid())
  eventId     String
  userId      String
  clubId      String
  status      AttendeeStatus @default(GOING)
  note        String?
  respondedAt DateTime       @default(now())

  event ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([clubId, eventId])
  @@index([userId, clubId])
}

// ─── Event & Order Payments ───────────────────────────────────────────────

// Created when a user registers for a paid event.
// BankMovement linked via source='EVENT', sourceId=eventPayment.id
model EventPayment {
  id        String        @id @default(cuid())
  eventId   String
  userId    String
  clubId    String        // denormalized
  amount    Decimal       @db.Decimal(14, 2)
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime      @default(now())

  event ClubEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])       // one payment record per user per event
  @@index([clubId, status])
  @@index([eventId])
}

// Created when an admin marks an order as paid.
// BankMovement linked via source='ORDER', sourceId=orderPayment.id
model OrderPayment {
  id        String        @id @default(cuid())
  orderId   String        @unique
  clubId    String        // denormalized
  amount    Decimal       @db.Decimal(14, 2)
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  note      String?
  createdAt DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([clubId, status])
}

// ─── Roles personalizados dentro del club ────────────────────────────────

model ClubCustomRole {
  id          String   @id @default(cuid())
  clubId      String
  name        String   // "Tesorero", "Secretario", "Capitán"
  description String?
  color       String?  // hex color for badge
  createdAt   DateTime @default(now())

  club    Club                   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  members ClubMemberCustomRole[]

  @@index([clubId])
}

model ClubMemberCustomRole {
  id           String @id @default(cuid())
  membershipId String
  customRoleId String

  membership ClubMembership @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  customRole ClubCustomRole @relation(fields: [customRoleId], references: [id], onDelete: Cascade)

  @@unique([membershipId, customRoleId])
}

// ─── Member Directory (pre-registration profiles) ─────────────────────────────
// Admin can create member profiles before the user registers.
// When a user registers and their membership is approved, profiles auto-link by email.

model ClubMemberProfile {
  id          String              @id @default(cuid())
  clubId      String

  // Core identity
  email       String
  firstName   String
  lastName    String
  phone       String?

  // Address
  address     String?
  city        String?
  postalCode  String?

  // Club-specific data
  birthDate     DateTime?
  jerseyNumber  String?
  licenseNumber String?
  joinDate      DateTime?
  notes         String?            @db.Text

  // Linking state
  status        MemberProfileStatus @default(UNREGISTERED)
  userId        String?             // set when linked to a real User account
  membershipId  String?             @unique // set when linked to ClubMembership

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club        Club            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user        User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  membership  ClubMembership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@unique([clubId, email])
  @@index([clubId])
  @@index([userId])
  @@index([clubId, status])
}

// ─── Soporte y Ticketing ──────────────────────────────────────────────────────

model Ticket {
  id            String         @id @default(cuid())
  code          String         @unique  // e.g. TK-0042 for quick reference

  subject       String
  description   String         @db.Text
  status        TicketStatus   @default(OPEN)
  priority      TicketPriority @default(LOW)
  category      TicketCategory

  // Scope: who created it and in which club context
  creatorId     String
  clubId        String?        // null = platform-level ticket (Club_ADMIN → SuperAdmin)

  // Assignment & escalation
  assignedToId  String?        // SuperAdmin userId handling this ticket
  escalatedAt   DateTime?
  escalatedById String?

  // Device / app metadata snapshot at creation time
  metadata      Json?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator    User          @relation("TicketCreator",   fields: [creatorId],    references: [id])
  club       Club?         @relation(fields: [clubId],  references: [id], onDelete: SetNull)
  assignedTo User?         @relation("TicketAssignee",  fields: [assignedToId], references: [id])
  escalatedBy User?        @relation("TicketEscalator", fields: [escalatedById],references: [id])
  messages   TicketMessage[]

  @@index([creatorId])
  @@index([clubId, status])
  @@index([status, priority])
  @@index([assignedToId])
}

model TicketMessage {
  id          String   @id @default(cuid())
  ticketId    String
  senderId    String
  body        String   @db.Text
  attachments String[] // URLs to uploaded files (S3 / Cloudinary)
  isInternal  Boolean  @default(false) // internal notes — only visible to admins

  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id])

  @@index([ticketId])
  @@index([senderId])
}
